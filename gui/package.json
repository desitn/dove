{
  "name": "dove-gui",
  "version": "0.2.6",
  "description": "Dove GUI - Firmware build and flash tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "destin.zhang@quectel.com",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  },
  "build": {
    "appId": "com.quectel.dove-gui",
    "productName": "Dove GUI",
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "webview/**/*"
    ],
    "extraResources": [
      {
        "from": "../dove.exe",
        "to": "dove.exe"
      }
    ]
  }
}